# Copy this to .env and fill values
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: force a specific model if auto-detection does not find one.
# Example: gemini-2.5-flash
GEMINI_MODEL=

# Comma-separated origins allowed to call the Flask API
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# true for local debugging, false for normal run
FLASK_DEBUG=true

# Optional Flask bind settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
